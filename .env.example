# Almacenamiento de envíos del formulario (Fase 5): cada SOP se guarda como un archivo
# .json commiteado a este mismo repo de GitHub, vía la API de GitHub (no hay base de datos).
#
# 1. Crea un token en https://github.com/settings/personal-access-tokens/new
#    - Repository access: solo este repositorio.
#    - Permissions → Contents: Read and write.
# 2. Crea una rama dedicada a los datos (ej. "data") para no mezclar código con envíos:
#    git checkout --orphan data && git commit --allow-empty -m "init" && git push -u origin data
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_DATA_BRANCH=data

# Panel interno /dashboard (Fase 7) — autenticación HTTP Basic.
# Define un usuario/clave propios; no uses los de ejemplo en producción.
DASHBOARD_USER=
DASHBOARD_PASSWORD=
